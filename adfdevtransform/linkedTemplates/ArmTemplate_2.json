						"defaultValue": "Person"
					},
					"Tablename": {
						"type": "string",
						"defaultValue": "Address"
					},
					"Containername": {
						"type": "string",
						"defaultValue": "onpremsql"
					},
					"dirname": {
						"type": "string",
						"defaultValue": "output"
					},
					"filename": {
						"type": "string",
						"defaultValue": "Person.Address.csv"
					}
				},
				"annotations": [],
				"lastPublishTime": "2026-03-10T16:23:46Z"
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/DS_sqlservertodatalakeparameterization')]",
				"[concat(variables('factoryId'), '/datasets/DS_sqltodatalakesinkparamtrize')]"
			]
		}
	]
