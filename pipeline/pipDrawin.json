{
	"name": "pipDrawin",
	"properties": {
		"activities": [
			{
				"name": "getFilemetadata",
				"type": "GetMetadata",
				"dependsOn": [],
				"policy": {
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"dataset": {
						"referenceName": "dsdatfile",
						"type": "DatasetReference",
						"parameters": {
							"Containername": {
								"value": "@pipeline().parameters.pipContainername",
								"type": "Expression"
							},
							"Dirname": {
								"value": "@pipeline().parameters.pipDirname",
								"type": "Expression"
							}
						}
					},
					"fieldList": [
						"childItems"
					],
					"storeSettings": {
						"type": "AzureBlobStorageReadSettings",
						"recursive": false,
						"enablePartitionDiscovery": false
					},
					"formatSettings": {
						"type": "BinaryReadSettings"
					}
				}
			},
			{
				"name": "ForEach1",
				"type": "ForEach",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [
					{
						"activity": "getFilemetadata",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('getFilemetadata').output.childItems",
						"type": "Expression"
					},
					"isSequential": false,
					"activities": [
						{
							"name": "innerGetFileMetadata",
							"type": "GetMetadata",
							"dependsOn": [],
							"policy": {
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"dataset": {
									"referenceName": "dsGetBlobFilemetadata",
									"type": "DatasetReference",
									"parameters": {
										"Filename": {
											"value": "@item().name",
											"type": "Expression"
										},
										"DIRName": {
											"value": "@pipeline().parameters.pipDirname",
											"type": "Expression"
										},
										"Containername": {
											"value": "@pipeline().parameters.pipContainername",
											"type": "Expression"
										}
									}
								},
								"fieldList": [
									"itemName",
									"size"
								],
								"storeSettings": {
									"type": "AzureBlobStorageReadSettings",
									"recursive": false,
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "BinaryReadSettings"
								}
							}
						},
						{
							"name": "uspDBA_UpsertFileFromBlob_copy1",
							"type": "SqlServerStoredProcedure",
							"state": "Inactive",
							"onInactiveMarkAs": "Succeeded",
							"dependsOn": [
								{
									"activity": "innerGetFileMetadata",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
								"retry": 0,
								"retryIntervalInSeconds": 30,
								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"storedProcedureName": "[dbo].[uspDBA_UpsertFileFromBlob]",
								"storedProcedureParameters": {
									"pFileName": {
										"value": {
											"value": "@activity('innerGetFileMetadata').output.itemName",
											"type": "Expression"
										},
										"type": "String"
									},
									"pFileSize": {
										"value": {
											"value": "@activity('innerGetFileMetadata').output.size",
											"type": "Expression"
										},
										"type": "Int64"
									}
								}
							},
							"linkedServiceName": {
								"referenceName": "LS_AzureSQLDB",
								"type": "LinkedServiceReference"
							}
						}
					]
				}
			}
		],
		"parameters": {
			"pipContainername": {
				"type": "string",
				"defaultValue": "darwinx"
			},
			"pipDirname": {
				"type": "string",
				"defaultValue": "landing"
			}
		},
		"annotations": []
	}
}