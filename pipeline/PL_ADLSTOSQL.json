{
	"name": "PL_ADLSTOSQL",
	"properties": {
		"activities": [
			{
				"name": "ADLStoSQLServer",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "DelimitedTextSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "DelimitedTextReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "DS_ADLSTOSQLServerSource",
						"type": "DatasetReference",
						"parameters": {
							"Inputcontname": {
								"value": "@pipeline().globalParameters.Inputcontainername_ADLS_landing",
								"type": "Expression"
							},
							"InputDirname": {
								"value": "@pipeline().globalParameters.InputDirname_learning",
								"type": "Expression"
							},
							"Inputfilename": {
								"value": "@pipeline().globalParameters.InputFilename_sales_details",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "DS_ADLSTOSQLServer_Sink",
						"type": "DatasetReference",
						"parameters": {
							"OutputSchema": {
								"value": "@pipeline().globalParameters.OutputSQLschema",
								"type": "Expression"
							},
							"Outputtable": {
								"value": "@pipeline().globalParameters.outputsqltable",
								"type": "Expression"
							}
						}
					}
				]
			}
		],
		"annotations": []
	}
}